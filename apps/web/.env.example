# jBurger Web (Next.js) — copiar a apps/web/.env.local
# Next.js carga .env.local desde el directorio de la aplicación, no desde la raíz del monorepo.

NEXT_PUBLIC_APP_ENV=local
# URL de la API. Debe coincidir con PORT de services/api/.env (por defecto 3001).
NEXT_PUBLIC_API_URL=http://localhost:3001

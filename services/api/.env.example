# jBurger API — variables de entorno
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
JWT_SECRET=local-development-secret-at-least-32-chars

# Supabase (proyecto "jburger"). Sin estas variables la API usa infraestructura in-memory
# con datos/credenciales demo (solo fuera de producción; en producción el bootstrap falla).
# - SUPABASE_ANON_KEY es pública por diseño (la usa el gateway de auth).
# - SUPABASE_SERVICE_ROLE_KEY se obtiene en Dashboard -> Project Settings -> API Keys. NUNCA commitearla.
SUPABASE_URL=https://atlhxzclsmcahqlfwdrm.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImF0bGh4emNsc21jYWhxbGZ3ZHJtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQyMTI4MzksImV4cCI6MjA5OTc4ODgzOX0.4OD1Xscqf1q_TZ6s5KE-i0Ec2ImowGOrRUOFMeUpTdQ
SUPABASE_SERVICE_ROLE_KEY=

# Carrito: límite operativo de unidades por ítem (techo absoluto en DB: 99).
MAX_CART_ITEM_QUANTITY=20

# Pagos — Mercado Pago (Checkout Pro). Sin ambas variables la API usa el proveedor mock
# (solo fuera de producción; en producción el bootstrap falla).
# Se obtienen en Mercado Pago -> Tus integraciones -> [aplicación] -> Credenciales / Webhooks.
# Usar credenciales SANDBOX para desarrollo y Acceptance. NUNCA commitearlas.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# URL pública de esta API: el proveedor le envía las notificaciones (en desarrollo, un túnel).
PUBLIC_API_URL=http://localhost:3001
# URL pública del frontend: destino del redirect posterior al pago.
PUBLIC_APP_URL=http://localhost:3000
